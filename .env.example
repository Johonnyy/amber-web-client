# Amber web client — server-side env (for the self-update feature).
# Copy to .env and fill in for production. None are needed for local dev.

# Require this token on POST /api/update. The client sends it from its
# "Update token" setting as the x-amber-update-token header. Leave unset on
# localhost to allow updates with no token.
AMBER_UPDATE_TOKEN=

# Branch the updater deploys (used by scripts/self-update.sh).
AMBER_UPDATE_BRANCH=master

# How the updater restarts the app after rebuilding (used by self-update.sh).
AMBER_RESTART_CMD=sudo systemctl restart amber-web

# RECOMMENDED IN PRODUCTION: run the updater fully OUTSIDE the web service's
# systemd cgroup so `systemctl restart` can't kill it mid-build. When set, this
# whole command is run instead of the default `bash scripts/self-update.sh`.
#   AMBER_UPDATE_CMD=sudo systemd-run --collect --unit=amber-web-update bash /opt/amber-web/scripts/self-update.sh

# Override the updater script path (when AMBER_UPDATE_CMD is unset).
# AMBER_UPDATE_SCRIPT=/opt/amber-web/scripts/self-update.sh

# Voice screen control (POST /api/screen, the set_screen client tool). Each is a
# shell command run on the host for that direction; a direction left unset is
# reported as "not set up" rather than failing. The command runs in THIS server
# process (amber-web.service, user `amber`), which has no X session — so it must
# reach the desktop user's display. Easiest is to hop to the kiosk user with the
# right DISPLAY (needs a one-line sudoers entry — see deploy/README.md):
#   AMBER_SCREEN_OFF_CMD=sudo -u johnny DISPLAY=:0 xset dpms force off
#   AMBER_SCREEN_ON_CMD=sudo -u johnny DISPLAY=:0 xset dpms force on
# The route reuses AMBER_UPDATE_TOKEN as the device-control token. Leave both
# unset to disable screen control.
